{
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://antyai-api.onrender.com/api/:path*"
    }
  ],
  "headers": [
    {
      "source": "/images/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ]
}
